# Anthropic API key — when set, Claude Code uses the API directly instead of
# the claude.ai subscription, bypassing claude.ai rate limits entirely.
# API usage is billed per token. See: https://console.anthropic.com/settings/keys
#
# Uncomment and paste your key:
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (default: sonnet)
# CLAUDE_AGENT_MODEL=sonnet
